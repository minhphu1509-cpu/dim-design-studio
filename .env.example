# ─── Database (PostgreSQL) ───────────────────────────────────────────
# Recommended: Neon (free) → https://neon.tech
DATABASE_URL="postgresql://user:password@host/dim_design_studio?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_URL="https://dim-design-studio.vercel.app"
NEXTAUTH_SECRET="your-secret-min-32-chars"

# ─── Cloudinary ──────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://dim-design-studio.vercel.app"
NEXT_PUBLIC_APP_NAME="Dim Design Studio"
